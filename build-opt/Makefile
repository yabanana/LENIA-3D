.PHONY : tests/core/test_lenia.o

# target to build an object file
tests/core/test_lenia.cc.o:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/lenia_tests.dir/build.make CMakeFiles/lenia_tests.dir/tests/core/test_lenia.cc.o
.PHONY : tests/core/test_lenia.cc.o

